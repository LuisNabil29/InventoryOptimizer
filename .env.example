# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password_change_me
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# Rol de aplicacion (sin BYPASSRLS) usado por web y engine
DATABASE_URL=postgresql://app:app_password_change_me@localhost:5432/inventory

# Rol privilegiado solo para migraciones / DDL
DATABASE_MIGRATION_URL=postgresql://postgres:postgres@localhost:5432/inventory

# Web (Next.js)
NEXTAUTH_SECRET=change_me
NEXTAUTH_URL=http://localhost:3000
ENGINE_URL=http://localhost:8000
ENGINE_INTERNAL_TOKEN=change_me_internal_token

# Engine (Python)
ENGINE_PORT=8000
